# Copy to secrets.yaml and fill in. secrets.yaml is git-ignored — never commit it.
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
ap_password: "fallback_ap_password"          # >= 8 chars; hotspot when Wi-Fi fails
api_password: "BASE64_HOME_ASSISTANT_API_ENCRYPTION_KEY"   # 32-byte base64 key
ota_password: "YOUR_OTA_PASSWORD"
